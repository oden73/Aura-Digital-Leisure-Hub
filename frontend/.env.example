# VITE_API_URL: Base URL of the Go core API (no trailing slash).
# Used only in production builds (`npm run build`).
#
# Local dev (`npm run dev`):
#   Leave unset — the app calls /v1/* on the same origin and Vite proxies
#   to the API (default target http://127.0.0.1:8080). Override with either:
#     VITE_API_URL=http://localhost:8080          (also sets proxy target via loadEnv)
#     VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080 (proxy only)
#
# Production (Vercel, etc.):
#   VITE_API_URL=https://aura-core.fly.dev        # (Fly.io)
#   VITE_API_URL=https://api.yourdomain.com        # (VPS)
VITE_API_URL=http://localhost:8080

# VITE_API_URL: Base URL of the Go core API (no trailing slash).
# Defaults to http://localhost:8080 when not set.
#
# Local dev:
#   VITE_API_URL=http://localhost:8080
#
# Vercel production — set in Vercel Dashboard → Project → Settings → Environment Variables:
#   VITE_API_URL=https://aura-core.fly.dev        # (Fly.io)
#   VITE_API_URL=https://api.yourdomain.com        # (VPS with reverse proxy)
VITE_API_URL=http://localhost:8080

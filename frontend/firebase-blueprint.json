{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "LibraryItem": {
      "title": "Library Item",
      "description": "An item saved in the user's library",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["game", "book", "movie"] },
        "title": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["to-watch", "watching", "completed", "dropped"] }
      },
      "required": ["itemId", "type", "title", "addedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback on a recommendation",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "sentiment": { "type": "string", "enum": ["liked", "disliked", "neutral"] },
        "moodTag": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "sentiment", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root user document"
    },
    "/users/{userId}/library/{itemId}": {
      "schema": "LibraryItem",
      "description": "User's personal library"
    },
    "/users/{userId}/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback for AI training"
    }
  }
}

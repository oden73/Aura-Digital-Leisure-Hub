## Backend local development environment
##
## Copy to `backend/.env` and adjust values if needed.
## Used by `backend/deployments/docker-compose.backend.yml`.

# Postgres container credentials / database name
POSTGRES_DB=aura
POSTGRES_USER=aura
POSTGRES_PASSWORD=aura

# Host port to expose Postgres on your machine
POSTGRES_PORT=5432

# ChromaDB (vector store) exposed port on your machine
CHROMA_PORT=8000

# Connection string used by services (defaults match the postgres container)
DATABASE_URL=postgres://aura:aura@postgres:5432/aura?sslmode=disable

# ChromaDB base URL used by the AI engine (when wired)
CHROMA_URL=http://chroma:8000

# JWT signing secret used by the Go core
JWT_SECRET=dev-secret

# Python AI engine endpoint and per-call timeout used by the Go core
AI_ENGINE_URL=http://ai-engine:8000
AI_ENGINE_TIMEOUT_MS=2000

# Logging
APP_ENV=development         # production switches slog to JSON output
LOG_LEVEL=info              # debug|info|warn|error

# CF similarity-cache tuning (optional)
SIMILARITY_CACHE_TTL_SECONDS=1800
USER_SIMILARITY_CACHE_MAX=100000
ITEM_SIMILARITY_CACHE_MAX=50000

# Graceful shutdown grace period (SIGINT/SIGTERM). The server will reject
# new connections and wait at most this long for in-flight requests to
# complete before forcing close.
SHUTDOWN_TIMEOUT_SECONDS=15

# CORS allowlist for the web client. Comma-separated origins; "*" allows
# any origin (and disables credentialed responses). Leave empty to fully
# disable CORS (same-origin only).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Token-bucket rate limit applied per authenticated user (or per IP for
# anonymous endpoints). Set RPS=0 to disable.
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40


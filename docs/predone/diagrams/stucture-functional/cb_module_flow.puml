@startuml
!theme plain
skinparam componentStyle uml2
skinparam packageStyle rectangle

package "Content-Based Module" {
    [Feature Extraction Component] as Extractor
    [Embedding Generation Component] as EmbGen
    [Similarity Computation Engine] as SimEngine
    [Cold Start Handler] as ColdStart
}

database "Relational Storage" {
    folder "Content Metadata"
    folder "User History Iu"
}

database "Vector Storage" {
    folder "Item Embeddings ei"
}

cloud "External Components" {
    [Embedding Model Provider] as EmbModel
}

Extractor --> "Relational Storage"
Extractor --> EmbGen
EmbGen --> EmbModel
EmbGen --> "Vector Storage"

SimEngine --> "Vector Storage"
SimEngine --> "Relational Storage"

ColdStart --> SimEngine
ColdStart --> Extractor

@enduml